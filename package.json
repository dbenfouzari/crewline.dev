{
  "name": "crewline",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "bun test --recursive",
    "typecheck": "tsc --build",
    "dev:server": "bun run --watch start-server.ts",
